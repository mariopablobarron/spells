---
import DemoBase from "@/layouts/DemoBase.astro";
---
<DemoBase title="Demo · Precio fluido">
  <div class="card">
    <p class="label">Cantidad</p>
    <div class="qty-row">
      <button data-qty="10">10</button>
      <button data-qty="25" class="active">25</button>
      <button data-qty="50">50</button>
      <button data-qty="100">100</button>
      <button data-qty="250">250</button>
    </div>
    <p class="price-label">Total estimado</p>
    <p class="price"><span id="price-eur">37</span><span class="comma">,</span><span id="price-cents">12</span> €</p>
    <p class="hint">Cambia la cantidad. El precio interpola en 350ms (ease-out cubic).</p>
  </div>
</DemoBase>

<style>
  .card {
    background: #f5f0e6;
    border: 1px solid #e8e2d5;
    border-radius: 24px;
    padding: 32px;
    width: 380px;
    text-align: center;
  }
  .label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: #1f1f22a0; margin: 0 0 12px; }
  .qty-row { display: flex; gap: 6px; justify-content: center; margin-bottom: 24px; }
  .qty-row button {
    flex: 1;
    background: #faf8f5;
    border: 1px solid #e8e2d5;
    border-radius: 999px;
    padding: 8px 4px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    color: #1f1f22;
    transition: all 0.15s;
  }
  .qty-row button:hover { border-color: #e63e73; }
  .qty-row button.active { background: #e63e73; color: white; border-color: #e63e73; }
  .price-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: #1f1f22a0; margin: 0 0 8px; }
  .price {
    font-family: "Fraunces", Georgia, serif;
    font-size: 56px;
    font-weight: 600;
    color: #1f1f22;
    margin: 0;
    font-variant-numeric: tabular-nums;
  }
  .price span.comma { color: #1f1f22; }
  .hint { font-size: 12px; color: #1f1f22b0; margin: 18px 0 0; }
</style>

<script>
  // Spell A2 — precio fluido con interpolación rAF + ease-out cubic.
  // Tabla de tiers: cantidad → unitPriceCents
  const TIERS = [
    { qty: 10, unit: 185 },
    { qty: 25, unit: 145 },  // -22%
    { qty: 50, unit: 115 },  // -38%
    { qty: 100, unit: 84 },  // -55%
    { qty: 250, unit: 59 },  // -68%
  ];

  const easeOutCubic = (t) => 1 - Math.pow(1 - t, 3);

  let currentTotal = TIERS[1].unit * TIERS[1].qty; // 25 uds × 1.45€ = 36.25€
  let raf = null;

  function setTotal(targetCents, duration = 350) {
    if (raf) cancelAnimationFrame(raf);
    const from = currentTotal;
    const to = targetCents;
    if (Math.abs(to - from) < 1 || window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      currentTotal = to;
      paint(to);
      return;
    }
    const start = performance.now();
    const tick = (now) => {
      const t = Math.min(1, (now - start) / duration);
      const v = Math.round(from + (to - from) * easeOutCubic(t));
      paint(v);
      if (t < 1) raf = requestAnimationFrame(tick);
      else { currentTotal = to; raf = null; }
    };
    raf = requestAnimationFrame(tick);
  }

  function paint(cents) {
    const eur = Math.floor(cents / 100);
    const c = String(cents % 100).padStart(2, "0");
    document.getElementById("price-eur").textContent = eur.toLocaleString("es-ES");
    document.getElementById("price-cents").textContent = c;
  }

  document.querySelectorAll(".qty-row button").forEach((btn) => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".qty-row button").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      const qty = parseInt(btn.dataset.qty, 10);
      const tier = TIERS.find((t) => t.qty === qty);
      if (tier) setTotal(tier.unit * tier.qty);
    });
  });

  paint(currentTotal);
</script>
