---
import Base from "@/layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const spells = await getCollection("spells");
  return spells.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

// Lista de slugs que tienen demo en /demo/<slug>/. Manualmente curada
// para no fallar 404 en iframes de spells sin demo aún.
const SLUGS_WITH_DEMO = new Set([
  "a1-confetti-add-to-cart",
  "a2-precio-fluido",
  "b1-carmen-onda-viva",
  "c1-cmd-k-palette",
  "c2-undo-toast",
]);
const hasDemo = SLUGS_WITH_DEMO.has(entry.id);
---
<Base title={`${d.title} · Spellbook`} description={d.summary}>
  <article class="mx-auto max-w-3xl px-6 py-14">
    <a href="/" class="text-xs text-ink/55 hover:text-accent">← Catálogo</a>
    <div class="mt-5 flex items-center gap-2 text-[10px] uppercase tracking-wider text-ink/55">
      <span class="rounded-full bg-bone-soft px-2 py-0.5">{d.category}</span>
      <span class="rounded-full bg-bone-soft px-2 py-0.5 font-mono">dificultad {d.difficulty}</span>
      <span>·</span>
      <time datetime={d.publishedAt.toISOString()}>
        {d.publishedAt.toLocaleDateString("es-ES", { day: "numeric", month: "long", year: "numeric" })}
      </time>
    </div>
    <h1 class="mt-3 font-display text-4xl font-semibold leading-tight lg:text-5xl">{d.title}</h1>
    <p class="mt-4 text-lg text-ink/75">{d.summary}</p>

    <div class="mt-6 flex flex-wrap items-center gap-3 text-xs text-ink/55">
      <span>Visto en:</span>
      {d.sourceUrl ? (
        <a class="rounded-full bg-bone-soft px-3 py-1 text-ink/85 hover:text-accent" href={d.sourceUrl} target="_blank" rel="noopener">
          {d.sourceProject} ↗
        </a>
      ) : (
        <span class="rounded-full bg-bone-soft px-3 py-1 text-ink/85">{d.sourceProject}</span>
      )}
      {d.tags.map((t) => (
        <span class="rounded-full bg-bone-soft px-3 py-1">{t}</span>
      ))}
    </div>

    {hasDemo && (
      <section class="mt-10">
        <div class="mb-3 flex items-center justify-between">
          <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-ink/60">
            Demo en vivo
          </p>
          <a
            href={`/demo/${entry.id}/`}
            target="_blank"
            rel="noopener"
            class="text-xs text-accent hover:underline"
          >
            Abrir en pantalla completa ↗
          </a>
        </div>
        <div class="overflow-hidden rounded-3xl border border-line bg-bone-soft">
          <iframe
            src={`/demo/${entry.id}/`}
            title={`Demo de ${d.title}`}
            loading="lazy"
            class="w-full"
            style="height: 480px; border: 0; display: block;"
          ></iframe>
        </div>
      </section>
    )}

    <div class="prose-spell mt-10">
      <Content />
    </div>

    <div class="mt-16 border-t border-line pt-6 text-xs text-ink/45">
      Licencia <strong>MIT</strong>. Atribución no requerida pero apreciada.
      Encontraste un bug o tienes una mejora? <a class="text-accent hover:underline" href="https://github.com/mariopablobarron">Abre un issue</a>.
    </div>
  </article>
</Base>
